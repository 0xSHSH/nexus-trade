# ─────────────────────────────────────────────────────────
#  NexusTrade — Environment Configuration
#  Copy this file to .env and fill in the values.
#  NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── AI Engine ─────────────────────────────────────────────
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_MAX_TOKENS=3072
GEMINI_TEMPERATURE=0.25

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRY_MINUTES=120

# ── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate Limits ───────────────────────────────────────────
RATE_LIMIT_INSIGHTS=8/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_WATCHLIST=30/minute

# ── Search ────────────────────────────────────────────────
SEARCH_MAX_RESULTS=6
SEARCH_CONTEXT_CHARS=18000
